		"lib",
		"c++",
		"addon",
		"bindings",
		"native",
		"gyp"
	],
	"files": [
		"include",
		"index.js",
		"index.d.ts",
		"install.js",
		"LIBUIOHOOK_LGPL.md",
		"LICENSE",
		"package.json",
		"README.md"
	],
	"scripts": {
		"postinstall": "node install.js",
		"test": "npm run test:watch",
