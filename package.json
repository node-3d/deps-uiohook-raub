		"lint:oxlint": "oxlint .",
		"lint:all": "npm run lint:oxlint"
	},
	"engines": {
		"node": ">=24.13.0",
		"npm": ">=11.6.2"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/node-3d/deps-uiohook.git"
	},
	"dependencies": {
